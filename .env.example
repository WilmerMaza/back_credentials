DATABASE_URL="postgresql://user:password@localhost:5432/credencial_db"
API_KEY=""
PORT=3000
UPLOADS_DIR="uploads/credentials"
JWT_SECRET=""
NODE_ENV="development"

# none = front y API en distinto puerto/host (ej. localhost:4002 → :3000)
# lax  = mismo origen (producción con nginx /api)
AUTH_COOKIE_SAMESITE=none

# Azure AD + Microsoft Graph (Exchange Online)
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SENDER_EMAIL=""
MAIL_FROM_NAME="Credencial Digital"
MAX_PDF_SIZE_MB=25

# Rate limiting (peticiones por IP por ventana THROTTLE_TTL en ms)
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=10
THROTTLE_WRITE_TTL=60000
THROTTLE_WRITE_LIMIT=30
THROTTLE_MAIL_TTL=60000
THROTTLE_MAIL_LIMIT=10
