AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SENDER_EMAIL=""
MAIL_FROM_NAME="Credencial Digital"
MAX_PDF_SIZE_MB=25
