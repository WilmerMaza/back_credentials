generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Person {
  id                 String       @id @default(cuid())
  firstName          String
  lastName           String
  fullName           String
  typeIdentity       String
  identityNumber     String       @unique
  birthDate          DateTime
  institutionalEmail String?      @unique
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  credentials        Credential[]
  user               User?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  personId  String?  @unique
  person    Person?  @relation(fields: [personId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credentialAuditLogs CredentialAuditLog[]
}

model CredentialType {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  schema      Json         @default("{\"fields\":[]}")
  createdAt   DateTime     @default(now())

  credentials Credential[]
}

model Credential {
  id               String           @id @default(cuid())
  personId         String
  credentialTypeId String

  details          String?
  metadata         Json             @default("{}")
  imagePath        String?

  issueDate        DateTime?
  expirationDate   DateTime?
  status           CredentialStatus @default(PENDING)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  person           Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  credentialType   CredentialType   @relation(fields: [credentialTypeId], references: [id])
  auditLogs        CredentialAuditLog[]

  @@index([personId])
  @@index([credentialTypeId])
}

enum CredentialAuditAction {
  CREATE
  UPDATE
}

model CredentialAuditLog {
  id           String                @id @default(cuid())
  credentialId String
  action       CredentialAuditAction
  userId       String?
  userEmail    String?
  before       Json?
  after        Json
  createdAt    DateTime              @default(now())

  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([credentialId])
  @@index([userId])
  @@index([createdAt])
}

enum CredentialStatus {
  ACTIVE
  PENDING
  EXPIRED
  TRANSFERRED
  REVOKED
  SUSPENDED
}
